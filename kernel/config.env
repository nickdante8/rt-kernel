# ==============================================================================
# KERNEL BUILD CONFIGURATION (config.env)
# ==============================================================================

# Script directory helper (determines the directory where this file resides)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Target Hardware ---
TARGET_BOARD="rpi3bplus"         # Raspberry Pi 3 Model B+
KERNEL_NAME="kernel8"            # kernel8 is the boot name for 64-bit ARM kernels
ARCH="arm64"
CROSS_COMPILE="aarch64-linux-gnu-"
# Standard unified config for ARM64 (includes RPi 3/4/5). If missing use defconfig (more script tweaking may be required)
# For RT configuration use bcm2711_rt_defconfig
DEFCONFIG="bcm2711_defconfig"

# --- Kernel Source ---
KERNEL_VERSION_MAJOR_MINOR="6.18"
KERNEL_VERSION_PATCH="29"
KERNEL_REPO="https://github.com/raspberrypi/linux.git"
KERNEL_BRANCH="rpi-${KERNEL_VERSION_MAJOR_MINOR}.y"       # 6.18 kernel branch
KERNEL_REVISION="a72a0085aeac23ac8aa76c90c476e20626046ea7" # Specific commit for 6.18.29
KERNEL_DEPTH=1                   # Depth of git clone (1 for shallow clone to save time/space)

# --- RT Configuration ---
ENABLE_RT=false                   # Enable PREEMPT_RT patch/mode
DOWNLOAD_RT_PATCH=false           # Set to true to download and apply the RT patch in case the repository doesn't have it
RT_PATCH_FILE="patch-${KERNEL_VERSION_MAJOR_MINOR}.${KERNEL_VERSION_PATCH}-rt4.patch.xz"
RT_PATCH_URL="https://mirrors.edge.kernel.org/pub/linux/kernel/projects/rt/${KERNEL_VERSION_MAJOR_MINOR}/${RT_PATCH_FILE}"

# --- Stripping (subsystems/drivers to disable in config) ---
STRIP_SOUND_VIDEO=false          # Disable Sound and video/HDMI support to reduce latency/overhead
STRIP_WIFI=true                  # Disable Wi-Fi to reduce latency/overhead
STRIP_BLUETOOTH=true             # Disable Bluetooth to reduce latency/overhead

# --- Isolation Configuration ---
ENABLE_ISOLATION=false           # Set to true to enable core isolation (isolcpus=2,3) on boot

# --- Build Options ---
BUILD_JOBS=$(nproc)                 # Number of parallel compilation jobs
if [[ ${ENABLE_RT} == true ]]; then
    LOCALVERSION="-RT-CUSTOM"       # Unique suffix so modular drivers don't conflict
    BUILD_DIR_NAME="linux-${KERNEL_VERSION_MAJOR_MINOR}.${KERNEL_VERSION_PATCH}-rt"
    BUILD_DIR_PATH="${SCRIPT_DIR}/${BUILD_DIR_NAME}"  # Location of cloned kernel repository
else
    LOCALVERSION="-BASELINE-CUSTOM" # Unique suffix so modular drivers don't conflict
    BUILD_DIR_NAME="linux-${KERNEL_VERSION_MAJOR_MINOR}.${KERNEL_VERSION_PATCH}-baseline"
    BUILD_DIR_PATH="${SCRIPT_DIR}/${BUILD_DIR_NAME}"  # Location of cloned kernel repository
fi


# --- SSH Remote Deployment ---
SSH_USER="<pi>"               # Username to connect to the RPi
SSH_HOST="<ip-address>"            # SSH hostname or IP address of the RPi
SSH_PORT="22"                    # SSH port
REMOTE_BOOT_DIR="/boot/firmware" # RPi boot directory (/boot/firmware on RPi OS Bookworm+)
REMOTE_TEMP_DIR="/tmp/kernel-install" # Temporary directory on RPi for installation files
KERNEL_IMG_NAME="${KERNEL_NAME}.img"
