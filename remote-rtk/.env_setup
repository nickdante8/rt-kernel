# Global testing
SYSTEM_SERVICE_ENV_VAR_FILE_NAME="service-env-var"
SYSTEM_SERVICE_ENV_VAR_FILE_PATH="${SCRIPT_DIR}/${SYSTEM_SERVICE_ENV_VAR_FILE_NAME}"
SETUP_FILE_CURRENT="${SCRIPT_DIR}/.setup_file_current"

# LED project location
LED_PROJECT_NAME="led-toggle"
LED_PROJECT_LOCATION="${SCRIPT_DIR}/${LED_PROJECT_NAME}"
LED_SERVICE_DELAY_START_TIME=1
LED_SERVICE_FILE_NAME="${LED_PROJECT_NAME}.service"
LED_SERVICE_ENABLE_FILE_NAME="${LED_PROJECT_NAME}.service"
LED_SERVICE_FILE_LOCAL_PATH="${LED_PROJECT_LOCATION}/${LED_SERVICE_FILE_NAME}"
LED_SERVICE_FILE_GLOBAL_PATH="/etc/systemd/system/${LED_SERVICE_FILE_NAME}"
LED_TOGGLE_WORKING_DIRECTORY="${LED_PROJECT_LOCATION}/build"
LED_TOGGLE_EXE_PATH="${LED_TOGGLE_WORKING_DIRECTORY}/${LED_PROJECT_NAME}"
LED_SERVICE_ENV_FILE_PATH="${SCRIPT_DIR}/service-env-var"

# test exec service
TEST_EXEC_PROJECT_NAME="test-exec"
TEST_EXEC_PROJECT_LOCATION="${SCRIPT_DIR}/${TEST_EXEC_PROJECT_NAME}"
TEST_EXEC_SERVICE_DELAY_START_TIME=0
TEST_EXEC_SERVICE_FILE_NAME="${TEST_EXEC_PROJECT_NAME}.service"
TEST_EXEC_SERVICE_ENABLE_FILE_NAME="${TEST_EXEC_PROJECT_NAME}.service"
TEST_EXEC_SERVICE_FILE_LOCAL_PATH="${TEST_EXEC_PROJECT_LOCATION}/${TEST_EXEC_SERVICE_FILE_NAME}"
TEST_EXEC_SERVICE_FILE_GLOBAL_PATH="/etc/systemd/system/${TEST_EXEC_SERVICE_FILE_NAME}"
TEST_EXEC_WORKING_DIRECTORY="${TEST_EXEC_PROJECT_LOCATION}"
TEST_EXEC_EXE_PATH="${TEST_EXEC_WORKING_DIRECTORY}/test_exec.sh"
TEST_EXEC_START_PATH="${TEST_EXEC_WORKING_DIRECTORY}/test_start.sh"
TEST_EXEC_STATE_PATH="${TEST_EXEC_WORKING_DIRECTORY}/test_state.sh"
TEST_EXEC_SERVICE_ENV_FILE_PATH="${SCRIPT_DIR}/service-env-var"
