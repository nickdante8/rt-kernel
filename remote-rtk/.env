# --- Test Configuration ---
TEST_TYPE_DEFAULT="default"
TEST_TYPE_RT="rt"
# Load type can be idle or load. For load 3 different test will be possible 
# load-net, load-usb, luad-net-usb
LOAD_TYPE_IDLE="idle"
LOAD_TYPE_NET="load-net"
LOAD_TYPE_USB="load-usb"
LOAD_TYPE_NET_USB="load-net-usb"
LOAD_TYPE="${LOAD_TYPE_IDLE}"
LOAD_TYPE_ALL_LIST=("${LOAD_TYPE_IDLE}" "${LOAD_TYPE_NET}" "${LOAD_TYPE_USB}" "${LOAD_TYPE_NET_USB}")
# Timing duration and pin toggle period
NOMINAL_PERIOD_US=1000000   # Square wave period in microseconds (e.g., 1000000 for 1 second)
CAPTURE_DURATION_S=60.0     # Capture duration in seconds (e.g., 300 for 5 minutes)
# Project and output paths
DATE=$(date +%Y-%m-%d-%H-%M-%S)
TEST_TYPE="${TEST_TYPE_DEFAULT}"
TEST_TYPE_FOLDER_NAME="${TEST_TYPE_DEFAULT}_${DATE}"
OUTPUT_DIR="${SCRIPT_DIR}/test_results/${TEST_TYPE_FOLDER_NAME}"

# LED project location
LED_PROJECT_NAME="led-toggle"
LED_PROJECT_LOCATION="${SCRIPT_DIR}/${LED_PROJECT_NAME}"
LED_SERVICE_DELAY_START_TIME=1
LED_SERVICE_FILE_NAME="${LED_PROJECT_NAME}.service"
LED_SERVICE_ENABLE_FILE_NAME="${LED_PROJECT_NAME}.service"
LED_SERVICE_FILE_LOCAL_PATH="${LED_PROJECT_LOCATION}/${LED_SERVICE_FILE_NAME}"
LED_SERVICE_FILE_GLOBAL_PATH="/etc/systemd/system/${LED_SERVICE_FILE_NAME}"
LED_TOGGLE_WORKING_DIRECTORY="${LED_PROJECT_LOCATION}/build"
LED_TOGGLE_EXE_PATH="${LED_TOGGLE_WORKING_DIRECTORY}/${LED_PROJECT_NAME}"
LED_SERVICE_ENV_FILE_PATH="${SCRIPT_DIR}/test-exec-service-env"

# System service environment file for test-exec and led-toggle
SYSTEM_SERVICE_ENV_FILE_PATH="${SCRIPT_DIR}/test-exec-service-env"
