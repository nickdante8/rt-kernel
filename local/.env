# --- Remote RPI Configuration ---
RPI_USER="pi" # The username on your Raspberry Pi
RPI_HOST="192.168.100.30" # The IP address of your Raspberry Pi

# --- Test Configuration ---
TEST_NAME_DEFAULT="default"
TEST_NAME_RT="rt"
CAPTURE_DURATION_S=10 # Capture duration in seconds (e.g., 300 for 5 minutes)
# Project and output paths
DATE=$(date +%Y-%m-%d-%H-%M-%S)
TEST_NAME="${TEST_NAME_DEFAULT}_${DATE}"
OUTPUT_DIR="${SCRIPT_DIR}/test_results/${TEST_NAME}"

# Saleae CLI configuration
SALEAE_CH_SOFT_PIN=0 # The Saleae digital channel connected to SOFT_PIN (GPIO 17)
SALEAE_CH_HARD_PIN=1 # The Saleae digital channel connected to HARD_PIN (GPIO 18)
SALEAE_AUTOMATION_PORT=10500
SALEAE_DEVICE_ID="FFFFFFFFFFFFFFFF"

# Python analysis script
PYTHON_MEASUREMENT_SCRIPT="${SCRIPT_DIR}/saleae/measurement.py"
PYTHON_PROCESSING_SCRIPT="${SCRIPT_DIR}/saleae/processing.py"