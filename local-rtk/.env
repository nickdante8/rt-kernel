# --- Remote RPI Configuration ---
RPI_USER="pi" # The username on your Raspberry Pi
RPI_HOST="192.168.2.2" # The IP address of your Raspberry Pi

# --- Test Configuration ---
TEST_TYPE_DEFAULT="default"
TEST_TYPE_RT="rt"
# Load type can be idle or load. For load 3 different test will be possible 
# load-net, load-usb, luad-net-usb
LOAD_TYPE_IDLE="idle"
LOAD_TYPE_NET="load-net"
LOAD_TYPE_USB="load-usb"
LOAD_TYPE_NET_USB="load-net-usb"
LOAD_TYPE="${LOAD_TYPE_IDLE}"
LOAD_TYPE_ALL_LIST=("${LOAD_TYPE_IDLE}" "${LOAD_TYPE_NET}" "${LOAD_TYPE_USB}" "${LOAD_TYPE_NET_USB}")
# Timing duration and pin toggle period
NOMINAL_PERIOD_US=1000000   # Square wave period in microseconds (e.g., 1000000 for 1 second)
CAPTURE_DURATION_S=60       # Capture duration in seconds (e.g., 300 for 5 minutes)
# Project and output paths
DATE=$(date +%Y-%m-%d-%H-%M-%S)
TEST_TYPE="${TEST_TYPE_DEFAULT}"
TEST_TYPE_FOLDER_NAME="${TEST_TYPE_DEFAULT}_${DATE}"
OUTPUT_DIR="${SCRIPT_DIR}/test_results/${TEST_TYPE_FOLDER_NAME}"

# Saleae CLI configuration
SALEAE_CH_SOFT_PIN=0 # The Saleae digital channel connected to SOFT_PIN (GPIO 17)
SALEAE_CH_HARD_PIN=1 # The Saleae digital channel connected to HARD_PIN (GPIO 18)
SALEAE_AUTOMATION_PORT=10500
SALEAE_DEVICE_ID="FFFFFFFFFFFFFFFF"

# Remote script paths
REMOTE_TEST_PATH="~/remote-rtk/test-exec"
REMOTE_TEST_START_SCRIPT_PATH="${REMOTE_TEST_PATH}/test_start.sh"
REMOTE_TEST_STATE_SCRIPT_PATH="${REMOTE_TEST_PATH}/test_state.sh"
REMOTE_TEST_OUTPUT_DIR="${REMOTE_TEST_PATH}/test_results"

# Python analysis script
PYTHON_MEASUREMENT_SCRIPT="${SCRIPT_DIR}/saleae/measurement.py"
PYTHON_PROCESSING_SCRIPT="${SCRIPT_DIR}/processing/run_test.py"
